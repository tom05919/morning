{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://morning.local/schemas/reports-bundle.json",
  "title": "Morning reports bundle",
  "description": "Consumed by the Morning SPA. reports[] must be newest-first (index 0 = Today).",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "generatedAt", "reports"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Bump when schema changes."
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 when the bundle was produced."
    },
    "reports": {
      "type": "array",
      "description": "Newest report first. Each id should be YYYY-MM-DD for that edition.",
      "items": { "$ref": "#/$defs/report" }
    },
    "user": {
      "description": "Optional. Null or omitted = site uses bundled defaults.",
      "oneOf": [{ "$ref": "#/$defs/user" }, { "type": "null" }]
    }
  },
  "$defs": {
    "report": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "date", "shortDate", "title", "topics", "readTime", "tldr", "sections", "sources"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "Edition date YYYY-MM-DD."
        },
        "date": {
          "type": "string",
          "minLength": 4,
          "description": "Human-readable full date, e.g. Thursday, April 23, 2026"
        },
        "shortDate": {
          "type": "string",
          "minLength": 1,
          "description": "Short label e.g. Apr 23"
        },
        "title": { "type": "string", "minLength": 1 },
        "topics": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "readTime": {
          "type": "integer",
          "minimum": 1,
          "maximum": 120,
          "description": "Estimated minutes to read."
        },
        "tldr": { "type": "string", "minLength": 1 },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["heading", "body"],
            "properties": {
              "heading": { "type": "string", "minLength": 1 },
              "body": { "type": "string", "minLength": 1 }
            }
          }
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["title", "author", "year"],
            "properties": {
              "title": { "type": "string", "minLength": 1 },
              "author": { "type": "string", "minLength": 1 },
              "year": { "type": "integer", "minimum": 1990, "maximum": 2100 }
            }
          }
        }
      }
    },
    "user": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "bookmarkedIds", "readThisWeek", "readThisMonth", "topicsCovered"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "bookmarkedIds": {
          "type": "array",
          "items": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        },
        "readThisWeek": { "type": "integer", "minimum": 0 },
        "readThisMonth": { "type": "integer", "minimum": 0 },
        "topicsCovered": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
